# ============================================
# AgentSupport Local Dev Environment Variables
# ============================================
# 1. Copy this file to .env:  cp .env.example .env  (or:  Copy-Item .env.example .env)
# 2. Fill in values from Supabase dashboard.
# 3. NEVER commit .env (already in .gitignore).
# ============================================

# ---- PostgreSQL (Supabase) ----
# Get from: Supabase dashboard -> Project Settings -> Database
# Use the "Direct connection" host (port 5432), NOT the pooler (port 6543).
# Spring Boot keeps long-lived connections; pooler is for serverless.
DB_HOST=db.xxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=

# Supabase requires SSL. Leave this as-is.
DB_SSL_MODE=require

# ---- Frontend ----
# Local dev points to local Spring Boot.
# In Vercel production, set NEXT_PUBLIC_API_BASE_URL to your Render URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ---- Backend ----
# CORS allowed origins (comma-separated). Local dev only.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Session cookie name (do not change without coordinated FE update)
SESSION_COOKIE_NAME=AGENT_SESSION

# Spring profile (local | prod). 'local' = .env-driven, 'prod' = Render env-driven.
SPRING_PROFILES_ACTIVE=local

# Note: sessions are stored in Supabase Postgres via Spring Session JDBC.
# No separate Redis required.

# 기본: 텍스트 파일은 LF로 정규화하여 저장, 체크아웃 시 OS에 맞게
* text=auto eol=lf

# 명시적으로 LF
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.sh text eol=lf
*.gradle text eol=lf
gradlew text eol=lf

# Windows 전용 스크립트는 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 바이너리 (수동 명시)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.jar binary
*.zip binary

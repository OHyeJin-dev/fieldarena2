{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest",
    "api:generate": "openapi-typescript ../docs/generated/openapi.yaml -o src/api/schema.d.ts",
    "tokens:check": "node ../scripts/tokens-check.js",
    "lint:fsd": "steiger ./src",
    "prepare": "cd .. && husky frontend/.husky || true"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.10",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@feature-sliced/steiger-plugin": "^0.5.8",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9",
    "openapi-typescript": "^7.13.0",
    "steiger": "^0.5.12",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
